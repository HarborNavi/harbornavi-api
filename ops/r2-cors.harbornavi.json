{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://harbornavi.com",
          "https://www.harbornavi.com",
          "http://localhost:4322"
        ],
        "methods": ["GET", "HEAD", "PUT"],
        "headers": ["Content-Type", "Cache-Control"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
