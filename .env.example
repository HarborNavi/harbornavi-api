HARBORNAVI_ADMIN_TOKEN=replace-with-a-long-random-token
HARBORNAVI_ALLOWED_ORIGINS=https://harbornavi.com,https://www.harbornavi.com,http://localhost:4322

# R2/S3-compatible upload signing.
STORAGE_DRIVER=r2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=harbornavi-assets
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_PUBLIC_BASE_URL=https://assets.harbornavi.com
ASSET_PREFIX=landing
LANDING_CONTENT_KEY=landing/content.json
